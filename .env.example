# LLM Provider: "anthropic" or "openai"
AI_PROVIDER=anthropic

# Anthropic (Claude) - required if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI - required if AI_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Model override (optional)
# Anthropic default: claude-sonnet-4-20250514
# OpenAI default: gpt-4o
AI_MODEL=

# Google Stitch integration (optional)
# Access token from: gcloud auth application-default print-access-token
# Or generate an API key at stitch.withgoogle.com > Settings > API Keys
STITCH_ACCESS_TOKEN=
# Google Cloud project ID with Stitch API enabled
STITCH_PROJECT_ID=
