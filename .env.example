# LLM Provider: "anthropic" or "openai"
AI_PROVIDER=anthropic

# Anthropic (Claude) - required if AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI - required if AI_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Model override (optional)
# Anthropic default: claude-sonnet-4-20250514
# OpenAI default: gpt-4o
AI_MODEL=

# Google Stitch integration (optional)
# Option 1 (recommended): API key from stitch.withgoogle.com > Settings > API Keys
STITCH_API_KEY=
# Option 2: OAuth access token from: gcloud auth application-default print-access-token
STITCH_ACCESS_TOKEN=
# Google Cloud project ID (only needed with OAuth, not with API key)
STITCH_PROJECT_ID=
